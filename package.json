{
  "name": "murmur",
  "version": "1.0.0",
  "description": "Electronを使ったパーソナルライフログ生成アプリ",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "pnpm run build:ts && electron . --dev",
    "build": "pnpm run build:ts && electron-builder",
    "build:ts": "tsc && tsc -p tsconfig.renderer.json",
    "build:watch": "tsc --watch & tsc -p tsconfig.renderer.json --watch",
    "type-check": "tsc --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "dist": "pnpm run build:ts && electron-builder --publish=never",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write \"**/*.{js,ts,json,html,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,html,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:all": "pnpm run test:ci && pnpm run test:e2e"
  },
  "keywords": [
    "electron",
    "voice",
    "memo",
    "obsidian",
    "openai",
    "whisper",
    "gpt"
  ],
  "author": "Your Name",
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "overrides": {
      "tar@<7.5.16": "^7.5.16",
      "js-yaml@<4.2.0": "^4.2.0",
      "@babel/core@<7.29.6": "^7.29.6"
    }
  },
  "devDependencies": {
    "@electron/typescript-definitions": "^9.1.6",
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/electron": "^1.4.38",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.64.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "jest": "^30.4.2",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "form-data": "^4.0.6",
    "fs-extra": "^11.3.6"
  },
  "build": {
    "appId": "com.yourname.murmur",
    "productName": "Murmur",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
